{
  "name": "@ijia/school-db",
  "version": "0.0.1",
  "imports": {
    "@/": "./src/",
    "@test/": "./test/",
    "@ijia/data/db": "./src/db.ts",
    "@ijia/data/oss": "./src/oss.ts",
    "@ijia/data/query": "./src/query.ts",
    "@ijia/data/testlib": "./src/testlib.ts"
  },
  "license": "MIT",
  "exports": {
    "./db": "./src/db.ts",
    "./oss": "./src/oss.ts",
    "./query": "./src/query.ts",
    "./testlib": "./src/testlib.ts",
    "./auth": "./src/auth.ts"
  },
  "publish": {
    "include": ["./sql/init", "./sql/create_merge.sh", "./src", "./README.md", "./LICENSE"]
  },
  "compilerOptions": {
    "lib": ["deno.window"]
  },
  "exclude": ["./lib.deno.d.ts", "./dist", "./build"],
  "fmt": {
    "lineWidth": 120
  },
  "tasks": {
    "commit-lint": "deno task check-fmt & deno task check-type",
    "check-fmt": "deno fmt --check ./src ./test ./scripts deno.json package.json",
    "check-type": "deno check src test",
    "doc:gen": "deno doc --name @ijia/school-db --html --output=docs/api src/db.ts src/oss.ts src/query.ts src/testlib.ts src/util.ts src/yoursql.ts",
    "build": "deno run -c build/deno.jsonc -A build/build.ts",
    "test": "deno x vitest run",
    "test:node": "node ./node_modules/vitest/vitest.mjs run",
    "gen:types": "deno types > lib.deno.d.ts",
    "publish-dry-run": "deno publish --dry-run --allow-dirty",
    "recreate-db": "deno eval 'await import(\"@ijia/data/testlib\").then((mod) => mod.createInitIjiaDbForTest())'"
  },
  "nodeModulesDir": "manual"
}
