{
  "name": "@ijia/school-db",
  "version": "0.0.5-alpha.6",
  "imports": {
    "@asla/pg": "jsr:@asla/pg@^0.2.4",
    "@asla/yoursql": "jsr:@asla/yoursql@^0.14.0",

    "@/": "./src/",
    "@deno/vite-plugin": "npm:@deno/vite-plugin@^2.0.2",
    "@test/": "./test/",
    "@ijia/school-db/db": "./src/db.ts",
    "@ijia/school-db/oss": "./src/oss.ts",
    "@ijia/school-db/query": "./src/query.ts",
    "@ijia/school-db/testlib": "./src/testlib.ts",

    "vitest": "npm:vitest@^4.1.6",
    "evlib": "npm:evlib@^3.1.3",
    "@types/node": "npm:@types/node@^25.5.0"
  },
  "license": "Apache-2.0",
  "exports": {
    "./db": "./src/db.ts",
    "./oss": "./src/oss.ts",
    "./query": "./src/query.ts",
    "./testlib": "./src/testlib.ts",
    "./auth": "./src/auth.ts"
  },
  "publish": {
    "include": ["./sql/init/**", "./sql/create-merge.sh", "./src/**", "./LICENSE", "./README.md"]
  },
  "compilerOptions": {
    "lib": ["deno.window"]
  },
  "exclude": ["./dist", "./node_modules"],
  "fmt": {
    "lineWidth": 120
  },
  "tasks": {
    "build": "deno run -A npm:typescript/tsc -p tsconfig.json",
    "commit-lint": "deno task check-fmt & deno task check-type",
    "check-fmt": "deno fmt --check ./src ./test deno.json",
    "fmt": "deno fmt ./src ./test deno.json",
    "check-type": "deno check src test",
    "doc:gen": "deno doc --name @ijia/school-db --html --output=docs/api src/db.ts src/oss.ts src/query.ts src/testlib.ts src/auth.ts",
    "test": "deno x vitest run",
    "publish-dry-run": "deno publish --dry-run --allow-dirty",
    "recreate-db": "deno eval 'await import(\"@ijia/school-db/testlib\").then((mod) => mod.createInitIjiaDbForTest())'"
  },
  "nodeModulesDir": "manual"
}
